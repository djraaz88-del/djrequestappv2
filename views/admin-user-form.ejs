<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title><%= title %></title><style>body{font-family:Arial,sans-serif;margin:0;background:#1f2937;color:white}.wrap{max-width:860px;margin:0 auto;padding:24px}.card{background:#111827;padding:24px;border-radius:16px;border:1px solid #374151}label{display:block;margin-top:14px}input{width:100%;padding:12px;margin-top:8px;border-radius:10px;border:none;box-sizing:border-box}.actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}a,button{display:inline-block;padding:12px 14px;border-radius:10px;text-decoration:none;border:none;cursor:pointer;font-weight:bold}a{background:#374151;color:white}button{background:#7c3aed;color:white}.error{color:#fecaca}</style></head><body><div class="wrap"><div class="card"><h1><%= title %></h1><% if (error) { %><p class="error"><%= error %></p><% } %><form method="post"><label>Username</label><input type="text" name="username" value="<%= user?.username || '' %>" required><label>Display name</label><input type="text" name="display_name" value="<%= user?.display_name || '' %>" required><label>DJ slug</label><input type="text" name="dj_slug" value="<%= user?.dj_slug || '' %>" required><label><%= isEdit ? 'New password (leave blank to keep current)' : 'Password' %></label><input type="password" name="password" <%= isEdit ? '' : 'required' %>><label>YouTube API key</label><input type="text" name="youtube_api_key" value="<%= settings?.youtube_api_key || '' %>"><label>Search URL 1</label><input type="text" name="search_url_1" value="<%= settings?.search_url_1 || '' %>"><label>Search URL 2</label><input type="text" name="search_url_2" value="<%= settings?.search_url_2 || '' %>"><div class="actions"><button type="submit">Save</button><a href="/admin">Back</a></div></form></div></div></body></html>