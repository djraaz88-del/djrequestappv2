<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Settings</title><style>body{font-family:Arial,sans-serif;margin:0;background:#1f2937;color:white}.wrap{max-width:800px;margin:0 auto;padding:24px}.card{background:#111827;padding:24px;border-radius:16px;border:1px solid #374151}input,button,a{width:100%;padding:12px;margin-top:8px;margin-bottom:14px;border-radius:10px;border:none;box-sizing:border-box}button{background:#7c3aed;color:white;font-weight:bold;cursor:pointer}a{display:block;background:#374151;color:white;text-decoration:none;text-align:center}</style></head><body><div class="wrap"><div class="card"><h1>Settings</h1><% if (saved) { %><p>Settings saved.</p><% } %><form method="post" action="/settings"><label>YouTube API key</label><input type="text" name="youtube_api_key" value="<%= settings.youtube_api_key || '' %>"><label>Search URL 1</label><input type="text" name="search_url_1" value="<%= settings.search_url_1 || '' %>"><label>Search URL 2</label><input type="text" name="search_url_2" value="<%= settings.search_url_2 || '' %>"><button type="submit">Save</button></form><a href="/dashboard">Back</a></div></div></body></html>