<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Guest QR</title><style>body{font-family:Arial,sans-serif;margin:0;background:#1f2937;color:white}.wrap{max-width:700px;margin:0 auto;padding:24px;text-align:center}.card{background:#111827;padding:24px;border-radius:16px;border:1px solid #374151}img{max-width:320px;width:100%;height:auto;background:white;padding:12px;border-radius:12px}code{display:inline-block;margin-top:12px;background:#374151;padding:10px 12px;border-radius:8px}</style></head><body><div class="wrap"><div class="card"><h1><%= user.display_name %> Guest QR</h1><img src="<%= qrDataUrl %>" alt="Guest QR code"><div><code><%= guestUrl %></code></div></div></div></body></html>