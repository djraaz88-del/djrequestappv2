<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Admin</title><style>body{font-family:Arial,sans-serif;margin:0;background:#1f2937;color:white}.wrap{max-width:1200px;margin:0 auto;padding:24px}.topbar{display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:20px}.actions{display:flex;gap:10px;flex-wrap:wrap}a,button{display:inline-block;padding:10px 12px;border-radius:10px;text-decoration:none;border:none;cursor:pointer;font-weight:bold}a{background:#374151;color:white}.primary{background:#7c3aed;color:white}.danger{background:#ef4444;color:white}table{width:100%;border-collapse:collapse;background:#111827;border:1px solid #374151;border-radius:14px;overflow:hidden}th,td{padding:12px;border-bottom:1px solid #374151;text-align:left;vertical-align:top}.badge{display:inline-block;padding:4px 8px;border-radius:999px;background:#374151;font-size:12px}.live{background:#10b981}.off{background:#4b5563}.disabled{background:#7f1d1d}.row-actions{display:flex;gap:8px;flex-wrap:wrap}form.inline{display:inline}</style></head><body><div class="wrap"><div class="topbar"><div><h1>Administrator</h1><p>Manage DJs, guest request status, and settings access.</p></div><div class="actions"><a class="primary" href="/admin/users/new">Create DJ</a><form class="inline" method="post" action="/logout"><button type="submit">Logout</button></form></div></div><table><thead><tr><th>DJ</th><th>Status</th><th>Requests</th><th>Guest Links</th><th>Actions</th></tr></thead><tbody><% djs.forEach(function(dj) { %><tr><td><strong><%= dj.display_name %></strong><br><small><%= dj.username %></small><br><small>Slug: <%= dj.dj_slug %></small></td><td><span class="badge <%= dj.is_live ? 'live' : 'off' %>"><%= dj.is_live ? 'Live' : 'Offline' %></span><% if (!dj.is_enabled) { %><span class="badge disabled">Disabled</span><% } %></td><td>Open: <strong><%= dj.open_request_count %></strong><br>Total: <strong><%= dj.total_request_count %></strong></td><td><a href="/guest/<%= dj.dj_slug %>" target="_blank">Guest Page</a><a href="/guest/<%= dj.dj_slug %>/qr" target="_blank">QR</a></td><td><div class="row-actions"><a href="/admin/users/<%= dj.id %>/edit">Edit</a><form class="inline" method="post" action="/admin/users/<%= dj.id %>/toggle-enabled"><button type="submit"><%= dj.is_enabled ? 'Disable' : 'Enable' %></button></form><% if (dj.is_live) { %><form class="inline" method="post" action="/admin/users/<%= dj.id %>/stop-live"><button class="danger" type="submit">Stop Live</button></form><% } %></div></td></tr><% }) %></tbody></table></div></body></html>