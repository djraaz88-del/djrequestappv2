<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kiosk View</title>
  <style>
    :root { --bg:#1f2937; --panel:rgba(17,19,27,.92); --panel-2:rgba(255,255,255,.04); --line:rgba(255,255,255,.08); --text:#f5f7fb; --muted:#9ca3af; --accent:#7c3aed; --accent-2:#22d3ee; --accent-3:#ec4899; --danger:#ef4444; --shadow:0 24px 70px rgba(0,0,0,.45); --radius-xl:28px;}
    *{box-sizing:border-box} html,body{margin:0;min-height:100%;font-family:Arial,sans-serif;background:var(--bg);color:var(--text)}
    .page{max-width:1480px;margin:0 auto;padding:26px}.topbar{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:22px;flex-wrap:wrap}
    .brand-text h1{margin:0;font-size:clamp(1.8rem,3vw,3rem)} .brand-text p{margin:6px 0 0;color:var(--muted);line-height:1.5;font-size:.98rem}
    .top-actions{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
    .pill{padding:10px 14px;border-radius:999px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.05);color:#dbeafe;font-size:.95rem}
    .link-btn,button,.action-link{border:none;cursor:pointer;border-radius:14px;padding:13px 16px;font-size:.96rem;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;justify-content:center;gap:8px}
    .btn-primary{color:white;background:linear-gradient(135deg,var(--accent),var(--accent-3))}
    .btn-secondary{color:white;background:linear-gradient(135deg,#0f766e,var(--accent-2))}
    .btn-ghost{color:var(--text);background:rgba(255,255,255,.04);border:1px solid var(--line)}
    .btn-danger{color:#ffe4e6;background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.28)}
    .layout{display:grid;grid-template-columns:1.7fr 1fr;gap:22px;align-items:start}
    .panel{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius-xl);box-shadow:var(--shadow);overflow:hidden}
    .panel-header{padding:22px 24px 18px;border-bottom:1px solid var(--line)}
    .panel-body{padding:22px 24px 24px}
    .search-row{display:grid;grid-template-columns:1fr auto;gap:12px;margin-bottom:12px}
    input{width:100%;padding:16px 18px;border-radius:16px;border:1px solid rgba(255,255,255,.09);background:rgba(255,255,255,.05);color:var(--text);font-size:1rem;outline:none}
    .subnote,.message{min-height:24px;font-size:.94rem;line-height:1.45;margin-bottom:14px}.subnote{color:var(--muted)} .message{color:#c4b5fd}
    .results,.queue{display:grid;gap:14px}
    .song-card{display:grid;grid-template-columns:156px 1fr auto;gap:16px;padding:12px;border-radius:20px;background:var(--panel-2);border:1px solid rgba(255,255,255,.07);align-items:center}
    .song-card img{width:100%;height:98px;object-fit:cover;border-radius:14px;display:block;background:#0b1220}
    .song-title{margin:0 0 7px;font-size:1rem;font-weight:700;line-height:1.35}
    .song-meta{color:var(--muted);font-size:.9rem;line-height:1.45}
    .song-preview{display:inline-block;margin-top:8px;padding:6px 10px;border-radius:999px;background:rgba(34,211,238,.12);color:#a5f3fc;font-size:.82rem;font-weight:700}
    .queue-controls{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px}
    .queue-item{display:grid;grid-template-columns:auto 1fr auto;gap:12px;align-items:center;padding:13px 14px;border-radius:18px;background:var(--panel-2);border:1px solid rgba(255,255,255,.07)}
    .queue-number{width:38px;height:38px;border-radius:12px;display:grid;place-items:center;background:linear-gradient(135deg,rgba(124,58,237,.35),rgba(34,211,238,.3));color:white;font-weight:800;font-size:.95rem}
    .queue-title{font-weight:700;line-height:1.35;margin-bottom:4px}.queue-sub{color:var(--muted);font-size:.89rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .queue-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end}
    .empty{padding:22px;border-radius:18px;border:1px dashed rgba(255,255,255,.12);background:rgba(255,255,255,.025);color:var(--muted);text-align:center;line-height:1.5}
    .loading-frame{min-height:260px;display:flex;align-items:flex-start;justify-content:center;padding-top:36px;border-radius:22px;border:1px dashed rgba(255,255,255,.12);background:linear-gradient(180deg,rgba(124,58,237,.10),rgba(34,211,238,.05)),rgba(255,255,255,.025);text-align:center}
    .loading-title{font-size:clamp(1.6rem,3vw,2.25rem);font-weight:800;margin-bottom:10px;color:#f5d0fe}
    @media (max-width:1040px){.layout{grid-template-columns:1fr}} @media (max-width:760px){.search-row{grid-template-columns:1fr}.song-card{grid-template-columns:1fr}.song-card img{height:180px}}
  </style>
</head>
<body>
  <div class="page">
    <div class="topbar">
      <div class="brand-text">
        <h1>DJ Request Booth</h1>
        <p>You can search YouTube and add tracks to the live request queue for <strong><%= user.display_name %></strong>.</p>
      </div>
      <div class="top-actions">
        <div class="pill" id="queueCount">0 requests saved</div>
        <a class="link-btn btn-ghost" href="/dashboard">Back to Dashboard</a>
      </div>
    </div>

    <div class="layout">
      <section class="panel">
        <div class="panel-header">
          <h2>Search Songs</h2>
          <p>Search by title, artist, remix, soundtrack, or version. Add the correct result to the queue on the right.</p>
        </div>
        <div class="panel-body">
          <div class="search-row">
            <input id="searchInput" type="text" placeholder="Search YouTube for a song" />
            <button class="btn-primary" id="searchBtn">Search</button>
          </div>
          <div class="subnote" id="apiStatus"></div>
          <div class="message" id="message"></div>
          <div class="results" id="results"></div>
        </div>
      </section>

      <aside class="panel">
        <div class="panel-header">
          <h2>Live Request Queue</h2>
          <p>Requests added here will appear in DJ View. This page does not include DJ-only controls.</p>
        </div>
        <div class="panel-body">
          <div class="queue-controls">
            <button class="btn-secondary" id="exportBtn">Export List</button>
            <button class="btn-danger" id="clearQueueBtn">Clear All</button>
          </div>
          <div class="queue" id="queue"></div>
        </div>
      </aside>
    </div>
  </div>

  <script>
    const apiKey = <%- JSON.stringify(settings?.youtube_api_key || '') %>;
    const elements = {searchInput:document.getElementById('searchInput'),searchBtn:document.getElementById('searchBtn'),results:document.getElementById('results'),queue:document.getElementById('queue'),message:document.getElementById('message'),clearQueueBtn:document.getElementById('clearQueueBtn'),exportBtn:document.getElementById('exportBtn'),queueCount:document.getElementById('queueCount'),apiStatus:document.getElementById('apiStatus')};
    let latestResults = [];
    function escapeHtml(v){return String(v||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;')}
    function formatDate(s){const d=new Date(s); if(Number.isNaN(d.getTime())) return ''; return d.toLocaleString()}
    function setMessage(t,e=false){elements.message.textContent=t; elements.message.style.color=e?'#fecdd3':'#ddd6fe'}
    function showLoadingFrame(){elements.results.innerHTML=`<div class="loading-frame"><div><div class="loading-title">Loading</div><div>Click add request when you have found your song.</div></div></div>`}
    function extractSongInfo(rawTitle,fallbackChannel=''){const original=String(rawTitle||'').trim(); let cleaned=original.replace(/\[[^\]]*\]/g,' ').replace(/\([^)]*(official|video|audio|lyrics|lyric video|hd|hq|4k|visualizer|visualiser|music video|mv|remastered|topic)[^)]*\)/gi,' ').replace(/\b(official video|official audio|lyric video|lyrics|audio|video|visualizer|visualiser|music video|mv|hd|hq|4k|remastered)\b/gi,' ').replace(/\s+/g,' ').trim(); let artist=''; let song=cleaned; if(cleaned.includes(' - ')){const parts=cleaned.split(' - ').map(p=>p.trim()).filter(Boolean); if(parts.length>=2){artist=parts[0]; song=parts.slice(1).join(' - ')}} else if(cleaned.includes(' | ')){const parts=cleaned.split(' | ').map(p=>p.trim()).filter(Boolean); if(parts.length>=2){artist=parts[0]; song=parts[1]}} if(!artist){artist=String(fallbackChannel||'').replace(/\s*-\s*topic$/i,'').trim()} return {songName:song||cleaned||original||'Unknown song', artistName:artist||'Unknown artist'}}
    function extractSearchTitle(rawTitle,fallbackTitle=''){const raw=String(rawTitle||'').trim(); if(!raw) return String(fallbackTitle||'').trim(); let t=raw.includes('|')?raw.split('|')[0].trim():raw; t=t.replace(/[\(\[].*?[\)\]]/g,'').trim(); if(t.includes(' - ')){const parts=t.split(' - ').map(p=>p.trim()).filter(Boolean); t=parts[parts.length-1]||t} t=t.replace(/\s+/g,' ').trim(); if(!t){t=String(fallbackTitle||raw).trim().replace(/[\(\[].*?[\)\]]/g,'').trim()} return t}
    function updateApiStatus(){ if(apiKey){elements.apiStatus.textContent='YouTube API key found. Search is ready.'; elements.apiStatus.style.color='#a7f3d0'} else {elements.apiStatus.textContent='No API key found yet. Open Settings to add your YouTube Data API key.'; elements.apiStatus.style.color='#fbcfe8'}}
    async function fetchQueue(){const res=await fetch('/api/requests',{credentials:'same-origin'}); if(!res.ok) throw new Error('Could not load queue'); return res.json()}
    async function renderQueue(){try{const queue=await fetchQueue(); elements.queueCount.textContent=`${queue.length} request${queue.length===1?'':'s'} saved`; if(!queue.length){elements.queue.innerHTML='<div class="empty">No song requests yet.</div>'; return} elements.queue.innerHTML=queue.map((item,index)=>{const title=escapeHtml(item.song_name||item.raw_title); const artist=escapeHtml(item.artist_name||item.channel_title||'Unknown artist'); const channel=escapeHtml(item.channel_title||'Unknown channel'); const added=escapeHtml(formatDate(item.added_at)); const youtubeUrl=item.video_id?`https://www.youtube.com/watch?v=${encodeURIComponent(item.video_id)}`:''; return `<div class="queue-item"><div class="queue-number">${index+1}</div><div><div class="queue-title">${title}</div><div class="queue-sub">${artist} • Source: ${channel} • Requested ${added}</div></div><div class="queue-actions">${youtubeUrl?`<a href="${youtubeUrl}" target="_blank" rel="noopener noreferrer" class="action-link btn-ghost">See Video</a>`:''}<button class="btn-danger" onclick="removeFromQueue(${item.id})">Remove</button></div></div>`}).join('')}catch(e){elements.queue.innerHTML='<div class="empty">Could not load queue.</div>'}}
    function renderResults(items=[]){if(!items.length){elements.results.innerHTML='<div class="empty">Search results will appear here.</div>'; return} elements.results.innerHTML=items.map(item=>{const title=escapeHtml(item.snippet.title); const channel=escapeHtml(item.snippet.channelTitle||'Unknown channel'); const parsed=extractSongInfo(item.snippet.title,item.snippet.channelTitle); const previewSearch=extractSearchTitle(item.snippet.title,parsed.songName); const thumbnail=item.snippet.thumbnails?.medium?.url || item.snippet.thumbnails?.default?.url || ''; const videoId=item.id.videoId; return `<div class="song-card"><img src="${thumbnail}" alt="Thumbnail for ${title}"><div><div class="song-title">${escapeHtml(parsed.songName)}</div><div class="song-meta">${escapeHtml(parsed.artistName)}<br>Source: ${channel}<br><span class="song-preview">Search preview: ${escapeHtml(previewSearch)}</span></div></div><div><button class="btn-primary" onclick="addToQueue('${videoId}')">Add Request</button></div></div>`}).join(''); latestResults=items}
    async function searchYouTube(){const query=elements.searchInput.value.trim(); if(!apiKey){setMessage('Add your YouTube API key in Settings first.',true); return} if(!query){setMessage('Type a song name or artist to search.',true); return} setMessage('Searching YouTube...'); elements.searchBtn.disabled=true; showLoadingFrame(); try{const params=new URLSearchParams({part:'snippet', type:'video', videoCategoryId:'10', maxResults:'10', q:query, key:apiKey}); const response=await fetch(`https://www.googleapis.com/youtube/v3/search?${params.toString()}`); const data=await response.json(); if(!response.ok) throw new Error(data?.error?.message || 'Search failed.'); const items=Array.isArray(data.items)?data.items:[]; if(!items.length){renderResults([]); setMessage('No songs found for that search.',true); return} renderResults(items); setMessage(`Found ${items.length} result${items.length===1?'':'s'}.`)}catch(error){renderResults([]); setMessage(`Search failed: ${error.message}`,true)} finally{elements.searchBtn.disabled=false}}
    window.addToQueue=async function(videoId){const item=latestResults.find(r=>r.id.videoId===videoId); if(!item){setMessage('Could not add that song.',true); return} try{const parsed=extractSongInfo(item.snippet.title,item.snippet.channelTitle); const res=await fetch('/api/requests',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify({video_id:videoId,raw_title:item.snippet.title,song_name:parsed.songName,artist_name:parsed.artistName,channel_title:item.snippet.channelTitle,requested_from:'kiosk'})}); if(!res.ok) throw new Error('Could not save request.'); alert('Your request has been sent to the DJ. If it suits the vibe, the DJ will try to play it soon.');setMessage('Ready for a new search.');elements.searchInput.value = '';latestResults = [];renderResults([]); renderQueue()}catch(error){setMessage(error.message||'Could not add request.',true)}}
    window.removeFromQueue=async function(id){try{const res=await fetch(`/api/requests/${id}`,{method:'DELETE',credentials:'same-origin'}); if(!res.ok) throw new Error('Could not remove request.'); setMessage('Song removed from the queue.'); renderQueue()}catch(error){setMessage(error.message||'Could not remove request.',true)}}
    async function clearQueue(){try{const queue=await fetchQueue(); if(!queue.length){setMessage('The queue is already empty.'); return} if(!window.confirm('Clear the full request queue?')) return; for(const item of queue){await fetch(`/api/requests/${item.id}`,{method:'DELETE',credentials:'same-origin'})} setMessage('All requests cleared.'); renderQueue()}catch(e){setMessage('Could not clear queue.',true)}}
    async function exportQueue(){try{const queue=await fetchQueue(); if(!queue.length){setMessage('There are no requests to export.',true); return} const lines=queue.map((item,index)=>`${index+1}. ${item.song_name||item.raw_title} - ${item.artist_name||item.channel_title||'Unknown artist'} - https://www.youtube.com/watch?v=${item.video_id}`); const blob=new Blob([lines.join('\\n')],{type:'text/plain;charset=utf-8'}); const url=URL.createObjectURL(blob); const a=document.createElement('a'); a.href=url; a.download='dj-request-queue.txt'; a.click(); URL.revokeObjectURL(url); setMessage('Queue exported.')}catch(e){setMessage('Could not export queue.',true)}}
    elements.searchBtn.addEventListener('click',searchYouTube); elements.clearQueueBtn.addEventListener('click',clearQueue); elements.exportBtn.addEventListener('click',exportQueue); elements.searchInput.addEventListener('keydown',e=>{if(e.key==='Enter') searchYouTube()});
    updateApiStatus(); renderQueue(); renderResults([]); setInterval(renderQueue,5000);
  </script>
</body>
</html>
