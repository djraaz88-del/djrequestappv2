<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Dashboard</title><style>body{font-family:Arial,sans-serif;margin:0;background:#1f2937;color:white}.wrap{max-width:1000px;margin:0 auto;padding:24px}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin:20px 0}.card{background:#111827;padding:20px;border-radius:14px;border:1px solid #374151}a,button{display:inline-block;padding:12px 14px;border-radius:10px;text-decoration:none;border:none;cursor:pointer;font-weight:bold}a{background:#374151;color:white}.start{background:#10b981;color:white}.stop{background:#ef4444;color:white}.meta{color:#d1d5db}</style></head><body><div class="wrap"><h1>Welcome, <%= user.display_name %></h1><p class="meta">Guest requests are currently: <strong><%= user.is_live ? 'Active' : 'Inactive' %></strong></p><div class="grid"><div class="card"><a href="/kiosk" target="_blank">Open Kiosk View</a></div><div class="card"><a href="/dj-view" target="_blank">Open DJ View</a></div><div class="card"><a href="/settings">Settings</a></div><div class="card"><a href="/guest/<%= user.dj_slug %>/qr" target="_blank">Guest QR</a></div><div class="card"><a href="/guest/<%= user.dj_slug %>" target="_blank">Guest Mobile Page</a></div></div><form method="post" action="/session/start-guest-requests" style="display:inline;"><button class="start" type="submit">Start Guest Requests</button></form><form method="post" action="/session/stop-guest-requests" style="display:inline;"><button class="stop" type="submit">Stop Guest Requests</button></form><form method="post" action="/logout" style="margin-top:16px;"><button type="submit">Logout</button></form></div></body></html>