<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>DJ Login</title><style>body{font-family:Arial,sans-serif;margin:0;background:#1f2937;color:white;display:grid;place-items:center;min-height:100vh}.card{width:min(420px,92vw);background:#111827;padding:24px;border-radius:16px;border:1px solid #374151}input,button{width:100%;padding:12px;margin-top:8px;margin-bottom:14px;border-radius:10px;border:none;box-sizing:border-box}button{background:#7c3aed;color:white;font-weight:bold;cursor:pointer}.error{color:#fecaca}</style></head><body><div class="card"><h1>DJ Login</h1><% if (error) { %><p class="error"><%= error %></p><% } %><form method="post" action="/login"><label>Username</label><input type="text" name="username" required /><label>Password</label><input type="password" name="password" required /><button type="submit">Log In</button></form></div></body></html>